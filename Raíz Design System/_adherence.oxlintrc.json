{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/badges/**",
              "components/cards/**",
              "components/core/**",
              "components/forms/**",
              "components/navigation/**",
              "components/process/**",
              "ui_kits/raiz-website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Special Elite|Yellowtail|Inter))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Special Elite, Yellowtail, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='BlogCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:date|title|excerpt|href|key|ref|className|style|children)$/]",
        "message": "<BlogCard> doesn't accept that prop. Declared props: date, title, excerpt, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|fullWidth|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, fullWidth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|whatsapp)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'whatsapp'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:base|large)$/]",
        "message": "<Button> size must be one of 'base' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|dark|light)$/]",
        "message": "<Eyebrow> tone must be one of 'default' | 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabLabel|problemTitle|problemText|solutionText|key|ref|className|style|children)$/]",
        "message": "<FileCard> doesn't accept that prop. Declared props: tabLabel, problemTitle, problemText, solutionText."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<FooterLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|htmlFor|children|key|ref|className|style|children)$/]",
        "message": "<FormField> doesn't accept that prop. Declared props: label, htmlFor, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<NavLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProcessStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|body|key|ref|className|style|children)$/]",
        "message": "<ProcessStep> doesn't accept that prop. Declared props: label, body."
      },
      {
        "selector": "JSXOpeningElement[name.name='RootWordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:inverse|width|key|ref|className|style|children)$/]",
        "message": "<RootWordmark> doesn't accept that prop. Declared props: inverse, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='SealLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:showSubtext|inverse|key|ref|className|style|children)$/]",
        "message": "<SealLogo> doesn't accept that prop. Declared props: showSubtext, inverse."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|key|ref|className|style|children)$/]",
        "message": "<ServiceCard> doesn't accept that prop. Declared props: title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Stamp> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:approved|rejected)$/]",
        "message": "<Stamp> tone must be one of 'approved' | 'rejected'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepStamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:n|tone|key|ref|className|style|children)$/]",
        "message": "<StepStamp> doesn't accept that prop. Declared props: n, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepStamp'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|default)$/]",
        "message": "<StepStamp> tone must be one of 'light' | 'default'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
